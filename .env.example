# App
PORT=5000
HOST=localhost

# CORS
# Comma-separated list of allowed origins, or "*" for any (dev only).
# Example: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/openjob

# JWT
ACCESS_TOKEN_KEY=your_access_token_secret_here
REFRESH_TOKEN_KEY=your_refresh_token_secret_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASSWORD=your_mail_password

# S3 Object Storage
S3_ENDPOINT=https://your-s3-endpoint.com
S3_REGION=us-east-1
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET_NAME=openjob-bucket
